# Mail App Environment
# Copy this file to .env and fill in your values.

# Ollama model (changeable at runtime in UI)
OLLAMA_MODEL=hermes3:latest

# Ollama hosts - configure one or more. Unused ones can be empty or commented out.
OLLAMA_HOST_LOCAL=http://localhost:11434
# OLLAMA_HOST_LAN=http://192.168.x.x:11434
# OLLAMA_HOST_CLOUD=https://ollama.com
# OLLAMA_CLOUD_KEY=your-cloud-key

# Maildir paths
MAIL_INBOX=/path/to/maildir/INBOX
MAIL_SENT=/path/to/maildir/[Gmail]/Sent Mail

# Only scan mails after this date
MAIL_SCAN_SINCE=2025-05-01

# Backend port
PORT=3001
